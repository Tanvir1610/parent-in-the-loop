# ── Email Provider (pick ONE — all free tiers available) ─────
#
# OPTION A: Mailjet — easiest, 200 emails/day free, instant setup
#   1. Sign up at https://app.mailjet.com (free, no credit card)
#   2. Settings → API Keys → copy API Key and Secret Key
#   3. Senders → Add tanvir@supanovlabs.com → verify email
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_SECRET_KEY=your-mailjet-secret-key

# OPTION B: SMTP2GO — 1000 emails/month free
#   1. Sign up at https://app.smtp2go.com (free)
#   2. Settings → API Keys → Add API Key
#   3. Sender Domains → Add supanovlabs.com
# SMTP2GO_API_KEY=your-smtp2go-api-key

# OPTION C: Postmark — 100 emails/month free
#   1. Sign up at https://postmarkapp.com
#   2. Get Server API token from your server
# POSTMARK_SERVER_TOKEN=your-postmark-server-token

# Sender details (same for all providers)
EMAIL_FROM=tanvir@supanovlabs.com
EMAIL_FROM_NAME=Parent in the Loop
EMAIL_REPLY_TO=tanvir@supanovlabs.com

# ── AI Chatbot (Claude) ──────────────────────────────────
