# ─────────────────────────────────────────────────────────────────────────────
# EMAIL: No external API keys needed!
# All email sending is handled by Supabase Edge Function → Gmail SMTP (free).
#
# Set these secrets in Supabase (NOT here — never commit SMTP credentials):
#   supabase secrets set SMTP_HOST=smtp.gmail.com
#   supabase secrets set SMTP_PORT=465
#   supabase secrets set SMTP_TLS=true
#   supabase secrets set SMTP_USER=your-gmail@gmail.com
#   supabase secrets set SMTP_PASS="your-16-char-app-password"
#   supabase secrets set EMAIL_FROM=your-gmail@gmail.com
#   supabase secrets set EMAIL_FROM_NAME="Parent in the Loop"
#   supabase secrets set EMAIL_REPLY_TO=your-gmail@gmail.com
#
# See EMAIL_SETUP.md for full instructions.
# ─────────────────────────────────────────────────────────────────────────────
