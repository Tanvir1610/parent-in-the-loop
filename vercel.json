{
  "installCommand": "pnpm install --no-frozen-lockfile --strict-peer-dependencies=false",
  "framework": "nextjs",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/weekly-digest",
      "schedule": "0 9 * * 0"
    }
  ]
}